{% comment %}
  Rebla Water — Hero
  File: sections/rebla-hero.liquid
{% endcomment %}

{% liquid
  assign desktop_image = section.settings.desktop_image
  assign mobile_image = section.settings.mobile_image
  if mobile_image == blank
    assign mobile_image = desktop_image
  endif
%}

<section
  id="ReblaHero-{{ section.id }}"
  class="rebla-hero-{{ section.id }}"
  style="
    --rh-max-width: {{ section.settings.content_width }}px;
    --rh-desktop-height: {{ section.settings.desktop_height }}px;
    --rh-copy-width: {{ section.settings.copy_width }}px;
    --rh-heading: {{ section.settings.heading_color }};
    --rh-text: {{ section.settings.text_color }};
    --rh-button-bg: {{ section.settings.button_background }};
    --rh-button-text: {{ section.settings.button_text_color }};
    --rh-button-hover: {{ section.settings.button_hover_background }};
    --rh-mobile-bg: {{ section.settings.mobile_background }};
  "
>
  <div class="rh-desktop">
    <div class="rh-media">
      {% if desktop_image != blank %}
        {{
          desktop_image
          | image_url: width: 2600
          | image_tag:
            class: 'rh-image rh-image-desktop',
            widths: '960, 1280, 1600, 2000, 2400, 2600',
            sizes: '100vw',
            loading: 'eager',
            fetchpriority: 'high'
        }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'rh-placeholder' }}
      {% endif %}
    </div>

    {% if section.settings.desktop_fade > 0 %}
      <div class="rh-fade" aria-hidden="true"></div>
    {% endif %}

    <div class="rh-inner">
      <div class="rh-copy rh-copy--{{ section.settings.desktop_copy_position }}">
        {% if section.settings.heading != blank %}
          <h1 class="rh-heading">{{ section.settings.heading }}</h1>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="rh-description rte">{{ section.settings.description }}</div>
        {% endif %}

        {% if section.settings.button_label != blank %}
          <a
            class="rh-button"
            {% if section.settings.button_link != blank %}
              href="{{ section.settings.button_link }}"
            {% else %}
              role="link"
              aria-disabled="true"
            {% endif %}
          >
            <span>{{ section.settings.button_label }}</span>
            {% if section.settings.show_arrow %}
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M5 12h13M13 6l6 6-6 6"></path>
              </svg>
            {% endif %}
          </a>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="rh-mobile">
    <div class="rh-mobile-copy rh-mobile-copy--{{ section.settings.mobile_text_alignment }}">
      {% if section.settings.heading != blank %}
        <h1 class="rh-heading">{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="rh-description rte">{{ section.settings.description }}</div>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a
          class="rh-button"
          {% if section.settings.button_link != blank %}
            href="{{ section.settings.button_link }}"
          {% else %}
            role="link"
            aria-disabled="true"
          {% endif %}
        >
          <span>{{ section.settings.button_label }}</span>
          {% if section.settings.show_arrow %}
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h13M13 6l6 6-6 6"></path>
            </svg>
          {% endif %}
        </a>
      {% endif %}
    </div>

    <div class="rh-mobile-media">
      {% if mobile_image != blank %}
        {{
          mobile_image
          | image_url: width: 1400
          | image_tag:
            class: 'rh-image rh-image-mobile',
            widths: '480, 720, 960, 1200, 1400',
            sizes: '100vw',
            loading: 'eager'
        }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'rh-placeholder' }}
      {% endif %}
    </div>
  </div>
</section>

{% style %}
  #ReblaHero-{{ section.id }} {
    width: 100%;
    overflow: hidden;
    background: var(--rh-mobile-bg);
  }

  #ReblaHero-{{ section.id }} *,
  #ReblaHero-{{ section.id }} *::before,
  #ReblaHero-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  #ReblaHero-{{ section.id }} .rh-desktop {
    position: relative;
    min-height: var(--rh-desktop-height);
    overflow: hidden;
    background: #f7f8fa;
  }

  #ReblaHero-{{ section.id }} .rh-media,
  #ReblaHero-{{ section.id }} .rh-image-desktop,
  #ReblaHero-{{ section.id }} .rh-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #ReblaHero-{{ section.id }} .rh-image,
  #ReblaHero-{{ section.id }} .rh-placeholder {
    display: block;
  }

  #ReblaHero-{{ section.id }} .rh-image-desktop {
    object-fit: cover;
    object-position: {{ section.settings.desktop_image_position }};
  }

  #ReblaHero-{{ section.id }} .rh-fade {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      rgba(255,255,255,{{ section.settings.desktop_fade | divided_by: 100.0 }}) 0%,
      rgba(255,255,255,{{ section.settings.desktop_fade | times: 0.008 }}) 28%,
      rgba(255,255,255,0) 58%
    );
  }

  #ReblaHero-{{ section.id }} .rh-inner {
    position: relative;
    z-index: 2;
    width: min(100%, var(--rh-max-width));
    min-height: var(--rh-desktop-height);
    margin: 0 auto;
    padding: 0 {{ section.settings.desktop_side_padding }}px;
    display: flex;
    align-items: center;
  }

  #ReblaHero-{{ section.id }} .rh-copy {
    width: min(100%, var(--rh-copy-width));
  }

  #ReblaHero-{{ section.id }} .rh-copy--left {
    margin-right: auto;
    text-align: left;
  }

  #ReblaHero-{{ section.id }} .rh-copy--center {
    margin: 0 auto;
    text-align: center;
  }

  #ReblaHero-{{ section.id }} .rh-copy--right {
    margin-left: auto;
    text-align: left;
  }

  #ReblaHero-{{ section.id }} .rh-heading {
    margin: 0;
    color: var(--rh-heading);
    font-size: clamp(48px, 4.5vw, {{ section.settings.desktop_heading_size }}px);
    line-height: {{ section.settings.heading_line_height | divided_by: 100.0 }};
    letter-spacing: -0.05em;
    font-weight: 750;
    text-wrap: balance;
  }

  #ReblaHero-{{ section.id }} .rh-description {
    max-width: {{ section.settings.description_width }}px;
    margin-top: {{ section.settings.description_spacing }}px;
    color: var(--rh-text);
    font-size: {{ section.settings.desktop_text_size }}px;
    line-height: 1.5;
  }

  #ReblaHero-{{ section.id }} .rh-description p {
    margin: 0;
  }

  #ReblaHero-{{ section.id }} .rh-copy--center .rh-description {
    margin-left: auto;
    margin-right: auto;
  }

  #ReblaHero-{{ section.id }} .rh-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    min-height: 52px;
    margin-top: {{ section.settings.button_spacing }}px;
    padding: 14px 22px;
    border-radius: {{ section.settings.button_radius }}px;
    background: var(--rh-button-bg);
    color: var(--rh-button-text);
    text-decoration: none;
    font-size: 16px;
    font-weight: 650;
    line-height: 1;
    transition: transform .2s ease, background-color .2s ease, box-shadow .2s ease;
  }

  #ReblaHero-{{ section.id }} .rh-button svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform .2s ease;
  }

  #ReblaHero-{{ section.id }} .rh-button:hover {
    background: var(--rh-button-hover);
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(10, 27, 51, .14);
  }

  #ReblaHero-{{ section.id }} .rh-button:hover svg {
    transform: translateX(3px);
  }

  #ReblaHero-{{ section.id }} .rh-mobile {
    display: none;
  }

  @media screen and (max-width: 749px) {
    #ReblaHero-{{ section.id }} .rh-desktop {
      display: none;
    }

    #ReblaHero-{{ section.id }} .rh-mobile {
      position: relative;
      display: flex;
      flex-direction: column;
      background: var(--rh-mobile-bg);
      overflow: hidden;
    }

    #ReblaHero-{{ section.id }} .rh-mobile::after {
      content: "";
      position: absolute;
      left: -22%;
      bottom: 30%;
      width: 92%;
      height: 240px;
      z-index: 1;
      pointer-events: none;
      background: radial-gradient(ellipse at center, rgba(30, 110, 255, .12) 0%, rgba(30, 110, 255, .05) 38%, rgba(30, 110, 255, 0) 72%);
      filter: blur(18px);
    }

    #ReblaHero-{{ section.id }} .rh-mobile-copy {
      position: relative;
      z-index: 3;
      padding:
        {{ section.settings.mobile_padding_top }}px
        {{ section.settings.mobile_side_padding }}px
        {{ section.settings.mobile_padding_bottom }}px;
    }

    #ReblaHero-{{ section.id }} .rh-mobile-copy--left {
      text-align: left;
    }

    #ReblaHero-{{ section.id }} .rh-mobile-copy--center {
      text-align: center;
    }

    #ReblaHero-{{ section.id }} .rh-mobile-copy--center .rh-description {
      margin-left: auto;
      margin-right: auto;
    }

    #ReblaHero-{{ section.id }} .rh-heading {
      font-size: {{ section.settings.mobile_heading_size }}px;
      line-height: {{ section.settings.mobile_heading_line_height | divided_by: 100.0 }};
      letter-spacing: -0.045em;
    }

    #ReblaHero-{{ section.id }} .rh-description {
      max-width: {{ section.settings.mobile_description_width }}px;
      margin-top: {{ section.settings.mobile_description_spacing }}px;
      font-size: {{ section.settings.mobile_text_size }}px;
      line-height: 1.48;
    }

    #ReblaHero-{{ section.id }} .rh-button {
      min-height: 50px;
      margin-top: {{ section.settings.mobile_button_spacing }}px;
      padding: 13px 20px;
      font-size: 15px;
    }

    #ReblaHero-{{ section.id }} .rh-mobile-media {
      position: relative;
      z-index: 2;
      width: 100%;
      height: {{ section.settings.mobile_image_height }}px;
      margin-top: -52px;
      overflow: hidden;
    }

    #ReblaHero-{{ section.id }} .rh-mobile-media::before {
      content: "";
      position: absolute;
      inset: 0 0 auto 0;
      height: 82px;
      z-index: 2;
      pointer-events: none;
      background: linear-gradient(
        to bottom,
        var(--rh-mobile-bg) 0%,
        rgba(247, 248, 250, .72) 28%,
        rgba(247, 248, 250, .24) 62%,
        rgba(247, 248, 250, 0) 100%
      );
    }

    #ReblaHero-{{ section.id }} .rh-image-mobile,
    #ReblaHero-{{ section.id }} .rh-mobile-media .rh-placeholder {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: {{ section.settings.mobile_image_position }};
    }
  }

  @media screen and (min-width: 750px) and (max-width: 1100px) {
    #ReblaHero-{{ section.id }} .rh-inner {
      padding-left: 36px;
      padding-right: 36px;
    }

    #ReblaHero-{{ section.id }} .rh-copy {
      max-width: 460px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #ReblaHero-{{ section.id }} .rh-button,
    #ReblaHero-{{ section.id }} .rh-button svg {
      transition: none;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Rebla Hero",
  "tag": "section",
  "class": "section-rebla-hero",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Engineered clarity for every drop."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Premium reverse osmosis system engineered for cleaner, safer, better-tasting water.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop System"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "show_arrow",
      "label": "Show button arrow",
      "default": true
    },

    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "select",
      "id": "desktop_image_position",
      "label": "Desktop image position",
      "default": "center center",
      "options": [
        { "value": "left center", "label": "Left" },
        { "value": "center center", "label": "Center" },
        { "value": "right center", "label": "Right" }
      ]
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "If empty, the desktop image is used."
    },
    {
      "type": "select",
      "id": "mobile_image_position",
      "label": "Mobile image position",
      "default": "center center",
      "options": [
        { "value": "left center", "label": "Left" },
        { "value": "center center", "label": "Center" },
        { "value": "right center", "label": "Right" }
      ]
    },

    {
      "type": "header",
      "content": "Desktop layout"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 420,
      "max": 760,
      "step": 10,
      "unit": "px",
      "label": "Hero height",
      "default": 560
    },
    {
      "type": "range",
      "id": "content_width",
      "min": 1000,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "label": "Content width",
      "default": 1440
    },
    {
      "type": "range",
      "id": "desktop_side_padding",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Side padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "copy_width",
      "min": 360,
      "max": 700,
      "step": 10,
      "unit": "px",
      "label": "Text area width",
      "default": 540
    },
    {
      "type": "select",
      "id": "desktop_copy_position",
      "label": "Text position",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "desktop_heading_size",
      "min": 48,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 72
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "min": 85,
      "max": 120,
      "step": 1,
      "unit": "%",
      "label": "Heading line height",
      "default": 98
    },
    {
      "type": "range",
      "id": "description_width",
      "min": 280,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Description width",
      "default": 470
    },
    {
      "type": "range",
      "id": "desktop_text_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 18
    },
    {
      "type": "range",
      "id": "description_spacing",
      "min": 8,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Description spacing",
      "default": 24
    },
    {
      "type": "range",
      "id": "button_spacing",
      "min": 8,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Button spacing",
      "default": 28
    },
    {
      "type": "range",
      "id": "desktop_fade",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Left image fade",
      "default": 90
    },

    {
      "type": "header",
      "content": "Mobile layout"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top spacing",
      "default": 48
    },
    {
      "type": "range",
      "id": "mobile_side_padding",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Side padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 12,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 30
    },
    {
      "type": "range",
      "id": "mobile_heading_size",
      "min": 32,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 44
    },
    {
      "type": "range",
      "id": "mobile_heading_line_height",
      "min": 90,
      "max": 125,
      "step": 1,
      "unit": "%",
      "label": "Heading line height",
      "default": 102
    },
    {
      "type": "range",
      "id": "mobile_description_width",
      "min": 240,
      "max": 420,
      "step": 10,
      "unit": "px",
      "label": "Description width",
      "default": 360
    },
    {
      "type": "range",
      "id": "mobile_text_size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_description_spacing",
      "min": 8,
      "max": 36,
      "step": 2,
      "unit": "px",
      "label": "Description spacing",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_button_spacing",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Button spacing",
      "default": 22
    },
    {
      "type": "range",
      "id": "mobile_image_height",
      "min": 260,
      "max": 620,
      "step": 10,
      "unit": "px",
      "label": "Image height",
      "default": 420
    },
    {
      "type": "select",
      "id": "mobile_text_alignment",
      "label": "Text alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },

    {
      "type": "header",
      "content": "Colors and button"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#0A1B33"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Description",
      "default": "#0A1B33"
    },
    {
      "type": "color",
      "id": "mobile_background",
      "label": "Mobile background",
      "default": "#F7F8FA"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#1261D6"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button hover",
      "default": "#0B50B9"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "button_radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Button corner radius",
      "default": 7
    }
  ],
  "presets": [
    {
      "name": "Rebla Hero"
    }
  ]
}
{% endschema %}
