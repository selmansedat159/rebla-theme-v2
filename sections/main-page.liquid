<div class="page-width page-margin">
  <div class="grid">
    <div class="grid__item">
      <!-- Sayfa Başlığı (Hakkımızda vb.) -->
      <h1 class="main-page-title page-title h0">
        {{ page.title | escape }}
      </h1>
      
      <!-- Shopify Panelinde Yazdığın İçerik Metni -->
      <div class="rte">
        {{ page.content }}
      </div>
    </div>
  </div>
</div>

<style>
  .page-margin {
    margin-top: 50px;
    margin-bottom: 50px;
    padding: 0 20px;
  }
  .main-page-title {
    margin-bottom: 30px;
    font-family: var(--font-heading--family);
  }
  .rte {
    font-family: var(--font-body--family);
    line-height: 1.6;
  }
</style>

{% schema %}
{
  "name": "Page Content",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}