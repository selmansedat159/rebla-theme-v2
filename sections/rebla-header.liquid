{% comment %}
  REBLA HEADER V5
  Premium desktop + sticky + mobile header
{% endcomment %}

{% liquid
  assign nav_menu = section.settings.menu
%}

<style>
  #shopify-section-{{ section.id }}{position:relative;z-index:80}
  .rebla-v5{--ink:#0a1b33;--blue:#1e6bff;--line:rgba(10,27,51,.10);--soft:#f7f8fa;color:var(--ink);font-family:inherit}
  .rebla-v5 *{box-sizing:border-box}
  .rebla-v5 a{color:inherit;text-decoration:none}
  .rebla-v5 button{font:inherit;color:inherit}
  .rebla-v5 svg{display:block;width:22px;height:22px;fill:none;stroke:currentColor;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}
  .rebla-v5__desktop{background:#fff;border-bottom:1px solid var(--line)}
  .rebla-v5__bar{border-bottom:1px solid var(--line)}
  .rebla-v5__bar-inner,.rebla-v5__main-inner{width:min(calc(100% - 48px),1440px);margin:auto}
  .rebla-v5__bar-inner{min-height:46px;display:flex;justify-content:center;align-items:center}
  .rebla-v5__benefits{display:grid;grid-template-columns:repeat(3,auto);align-items:center}
  .rebla-v5__benefit{min-width:240px;padding:0 40px;display:flex;justify-content:center;align-items:center;gap:11px;font-size:12px;font-weight:650;white-space:nowrap}
  .rebla-v5__benefit+.rebla-v5__benefit{border-left:1px solid var(--line)}
  .rebla-v5__benefit svg{width:19px;height:19px}
  .rebla-v5__main-inner{min-height:100px;display:grid;grid-template-columns:minmax(200px,1fr) auto minmax(200px,1fr);align-items:center;gap:38px}
  .rebla-v5__brand{justify-self:start;display:flex;align-items:center}
  .rebla-v5__logo{display:block;width:auto;height:auto;max-width:{{ section.settings.logo_width }}px;max-height:72px}
  .rebla-v5__name{font-size:28px;font-weight:800;letter-spacing:-.03em}
  .rebla-v5__nav{justify-self:center}
  .rebla-v5__menu{list-style:none;margin:0;padding:0;display:flex;align-items:center;gap:clamp(30px,3.2vw,56px)}
  .rebla-v5__item{position:static}
  .rebla-v5__link{min-height:100px;display:flex;align-items:center;gap:9px;font-size:15px;font-weight:650;white-space:nowrap;border-bottom:2px solid transparent}
  .rebla-v5__item:hover>.rebla-v5__link,.rebla-v5__item:focus-within>.rebla-v5__link{color:var(--blue);border-bottom-color:var(--blue)}
  .rebla-v5__chev{width:7px;height:7px;border-right:1.5px solid currentColor;border-bottom:1.5px solid currentColor;transform:rotate(45deg) translateY(-2px)}
  .rebla-v5__actions{justify-self:end;display:flex;align-items:center;gap:16px}
  .rebla-v5__action{position:relative;width:38px;height:42px;padding:0;border:0;background:none;display:grid;place-items:center;cursor:pointer}
  .rebla-v5__badge{position:absolute;top:1px;right:-2px;min-width:18px;height:18px;padding:0 5px;border-radius:20px;background:var(--blue);color:#fff;display:grid;place-items:center;font-size:10px;font-weight:800}
  .rebla-v5__mega{position:absolute;left:0;right:0;top:100%;padding:16px 24px 0;background:#fff;border-top:1px solid var(--line);box-shadow:0 24px 55px rgba(10,27,51,.13);opacity:0;visibility:hidden;transform:translateY(8px);transition:.18s ease}
  .rebla-v5__item:hover .rebla-v5__mega,.rebla-v5__item:focus-within .rebla-v5__mega{opacity:1;visibility:visible;transform:none}
  .rebla-v5__mega-inner{width:min(100%,1440px);margin:auto;display:grid;grid-template-columns:240px minmax(0,1fr);gap:26px;padding-bottom:18px}
  .rebla-v5__promo,.rebla-v5__trust{background:var(--soft);border-radius:14px;overflow:hidden}
  .rebla-v5__promo{min-height:270px;padding:24px;display:flex;flex-direction:column;justify-content:space-between;background-size:cover;background-position:center bottom}
  .rebla-v5__promo h3{max-width:165px;margin:0;font-size:22px;line-height:1.15;font-weight:800;letter-spacing:-.03em}
  .rebla-v5__blue-link{color:var(--blue);font-size:13px;font-weight:750}
  .rebla-v5__columns{display:grid;grid-template-columns:repeat(3,minmax(0,1fr))}
  .rebla-v5__column{padding:12px 24px;border-left:1px solid var(--line)}
  .rebla-v5__column:first-child{border-left:0}
  .rebla-v5__column h3{margin:0 0 18px;font-size:12px;font-weight:800;text-transform:uppercase}
  .rebla-v5__column ul{list-style:none;margin:0 0 20px;padding:0}
  .rebla-v5__column li+li{margin-top:12px}
  .rebla-v5__column li a{font-size:13px;line-height:1.35}
  .rebla-v5__column li a:hover{color:var(--blue)}
  .rebla-v5__trust{padding:8px 20px;display:grid;align-content:center}
  .rebla-v5__trust-row{padding:18px 0;display:grid;grid-template-columns:30px 1fr;gap:12px;align-items:start}
  .rebla-v5__trust-row+.rebla-v5__trust-row{border-top:1px solid var(--line)}
  .rebla-v5__trust-row strong{display:block;font-size:13px;margin-bottom:3px}
  .rebla-v5__trust-row small{display:block;font-size:11px;opacity:.7;line-height:1.35}
  .rebla-v5__nsf{width:28px;height:28px;border:1.5px solid currentColor;border-radius:50%;display:grid;place-items:center;font-size:8px;font-weight:800}
  .rebla-v5__search-panel{position:absolute;top:100%;right:max(24px,calc((100% - 1440px)/2));z-index:90;width:min(420px,calc(100% - 32px));padding-top:10px}
  .rebla-v5__search-panel[hidden]{display:none}
  .rebla-v5__search-form{height:54px;display:grid;grid-template-columns:24px 1fr 32px;gap:10px;align-items:center;padding:0 14px;background:#fff;border:1px solid var(--line);border-radius:14px;box-shadow:0 18px 45px rgba(10,27,51,.16)}
  .rebla-v5__search-form svg{width:20px;fill:none;stroke:currentColor;stroke-width:1.7}
  .rebla-v5__search-form input{width:100%;border:0;outline:0;background:transparent;font:inherit;color:var(--ink)}
  .rebla-v5__search-close{border:0;background:transparent;font-size:25px;line-height:1;cursor:pointer;color:var(--ink)}
  .rebla-v5__featurebar{border-top:1px solid var(--line);background:#fff}
  .rebla-v5__featurebar-inner{width:min(100%,1440px);min-height:76px;margin:auto;display:grid;grid-template-columns:repeat(4,1fr)}
  .rebla-v5__feature{padding:14px 26px;display:grid;grid-template-columns:34px 1fr;gap:12px;align-items:center}
  .rebla-v5__feature+.rebla-v5__feature{border-left:1px solid var(--line)}
  .rebla-v5__feature svg{width:27px;height:27px;color:var(--ink)}
  .rebla-v5__feature strong{display:block;font-size:12px;margin-bottom:3px}
  .rebla-v5__feature small{display:block;font-size:10px;opacity:.66;line-height:1.35}
  .rebla-v5__sticky{position:fixed;top:14px;left:50%;width:min(calc(100% - 32px),1180px);z-index:100;opacity:0;visibility:hidden;pointer-events:none;transform:translate(-50%,-18px);transition:.2s ease}
  .rebla-v5.is-scrolled .rebla-v5__sticky{opacity:1;visibility:visible;pointer-events:auto;transform:translate(-50%,0)}
  .rebla-v5__sticky-inner{min-height:68px;padding:0 24px;display:grid;grid-template-columns:150px 1fr auto;align-items:center;gap:28px;background:rgba(255,255,255,.84);border:1px solid rgba(255,255,255,.7);border-radius:16px;box-shadow:0 16px 42px rgba(10,27,51,.15);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px)}
  .rebla-v5__sticky .rebla-v5__logo{max-width:112px;max-height:44px}
  .rebla-v5__sticky .rebla-v5__menu{justify-content:center;gap:30px}
  .rebla-v5__sticky .rebla-v5__link{min-height:68px;font-size:12px;border:0}
  .rebla-v5__mobile,.rebla-v5__drawer{display:none}
  .rebla-v5__drawer.is-open{display:block;position:fixed;inset:0;z-index:120}
  .rebla-v5__backdrop{position:absolute;inset:0;background:rgba(10,27,51,.38)}
  .rebla-v5__panel{position:relative;width:min(88vw,390px);height:100%;padding:22px;background:#fff;overflow:auto}
  .rebla-v5__drawer-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:22px}
  .rebla-v5__close{border:0;background:none;font-size:32px;cursor:pointer}
  .rebla-v5__drawer-list,.rebla-v5__drawer-sub{list-style:none;margin:0;padding:0}
  .rebla-v5__drawer-list>li{border-bottom:1px solid var(--line)}
  .rebla-v5__drawer-list>li>a{display:block;padding:17px 2px;font-weight:750}
  .rebla-v5__drawer-sub{padding:0 0 12px 14px}
  .rebla-v5__drawer-sub a{display:block;padding:8px 2px;font-size:13px;opacity:.78}

  @media(max-width:1100px){
    .rebla-v5__main-inner{grid-template-columns:170px 1fr auto;gap:20px}
    .rebla-v5__menu{gap:22px}
    .rebla-v5__link{font-size:13px}
    .rebla-v5__mega-inner{grid-template-columns:190px 1fr}
    .rebla-v5__trust{display:none}
    .rebla-v5__mega-inner{grid-template-columns:210px 1fr}
    .rebla-v5__featurebar-inner{grid-template-columns:repeat(2,1fr)}
    .rebla-v5__feature:nth-child(3){border-left:0;border-top:1px solid var(--line)}
    .rebla-v5__feature:nth-child(4){border-top:1px solid var(--line)}
  }

  @media(max-width:749px){
    .rebla-v5__desktop,.rebla-v5__sticky{display:none!important}
    .rebla-v5__mobile{display:block;background:#fff;border-bottom:1px solid var(--line)}
    .rebla-v5__mobile-top{min-height:48px;padding:0 12px;display:grid;grid-template-columns:repeat(4,1fr);align-items:center;border-bottom:1px solid var(--line)}
    .rebla-v5__mobile-benefit{min-width:0;padding:0 7px;display:flex;justify-content:center;align-items:center;gap:5px;font-size:9px;font-weight:700;text-align:center}
    .rebla-v5__mobile-benefit+.rebla-v5__mobile-benefit{border-left:1px solid var(--line)}
    .rebla-v5__mobile-benefit svg{width:16px;height:16px;flex:none}
    .rebla-v5__mobile-main{min-height:70px;padding:0 12px;display:grid;grid-template-columns:42px 1fr auto;align-items:center;gap:8px}
    .rebla-v5__hamburger{width:38px;height:38px;border:0;background:none;padding:0;display:grid;place-items:center;cursor:pointer}
    .rebla-v5__hamburger svg{width:24px;height:24px}
    .rebla-v5__mobile-brand{justify-self:center}
    .rebla-v5__mobile .rebla-v5__logo{max-width:118px;max-height:48px}
    .rebla-v5__mobile-actions{display:flex;align-items:center;gap:1px}
    .rebla-v5__mobile-actions .rebla-v5__action{width:34px}
  }
</style>

<div class="rebla-v5" id="ReblaV5-{{ section.id }}">
  <header class="rebla-v5__desktop">
    <div class="rebla-v5__bar">
      <div class="rebla-v5__bar-inner">
        <div class="rebla-v5__benefits">
          <div class="rebla-v5__benefit">
            <svg viewBox="0 0 24 24"><path d="M3 6h11v10H3zM14 9h4l3 3v4h-7z"/><circle cx="7" cy="18" r="2"/><circle cx="18" cy="18" r="2"/></svg>
            <span>{{ section.settings.shipping_text }}</span>
          </div>
          <div class="rebla-v5__benefit">
            <svg viewBox="0 0 24 24"><path d="M12 3l7 3v5c0 5-3 8-7 10-4-2-7-5-7-10V6z"/><path d="M9 12l2 2 4-5"/></svg>
            <span>{{ section.settings.warranty_text }}</span>
          </div>
          <a class="rebla-v5__benefit" href="tel:{{ section.settings.phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' }}">
            <svg viewBox="0 0 24 24"><path d="M6 3l4 4-2 3c1.5 3 3 4.5 6 6l3-2 4 4-2 3c-8 0-16-8-16-16z"/></svg>
            <span>{{ section.settings.phone }}</span>
          </a>
        </div>
      </div>
    </div>

    <div class="rebla-v5__main-inner">
      <a class="rebla-v5__brand" href="{{ routes.root_url }}">
        {% if section.settings.logo != blank %}
          {{ section.settings.logo | image_url: width: 600 | image_tag: class: 'rebla-v5__logo', loading: 'eager', alt: shop.name }}
        {% else %}
          <span class="rebla-v5__name">{{ shop.name }}</span>
        {% endif %}
      </a>

      <nav class="rebla-v5__nav" aria-label="Main navigation">
        <ul class="rebla-v5__menu">
          {% for link in nav_menu.links %}
            <li class="rebla-v5__item">
              <a class="rebla-v5__link" href="{{ link.url }}">{{ link.title }}{% if link.links != blank %}<span class="rebla-v5__chev"></span>{% endif %}</a>
              {% if link.links != blank %}
                <div class="rebla-v5__mega">
                  <div class="rebla-v5__mega-inner">
                    <div class="rebla-v5__promo"{% if section.settings.mega_image != blank %} style="background-image:linear-gradient(to bottom,rgba(247,248,250,.98),rgba(247,248,250,.70) 48%,rgba(247,248,250,.04)),url('{{ section.settings.mega_image | image_url: width: 700 }}')"{% endif %}>
                      <h3>{{ section.settings.mega_heading }}</h3>
                      <a class="rebla-v5__blue-link" href="{{ section.settings.mega_link | default: link.url }}">Shop System →</a>
                    </div>

                    <div class="rebla-v5__columns">
                      {% for child in link.links limit: 3 %}
                        <div class="rebla-v5__column">
                          <h3>{{ child.title }}</h3>
                          <ul>
                            {% if child.links != blank %}
                              {% for grandchild in child.links limit: 6 %}
                                <li><a href="{{ grandchild.url }}">{{ grandchild.title }}</a></li>
                              {% endfor %}
                            {% else %}
                              <li><a href="{{ child.url }}">Explore {{ child.title }}</a></li>
                              <li><a href="{{ child.url }}">Learn more</a></li>
                            {% endif %}
                          </ul>
                          <a class="rebla-v5__blue-link" href="{{ child.url }}">View All →</a>
                        </div>
                      {% endfor %}
                    </div>

                  </div>

                  <div class="rebla-v5__featurebar">
                    <div class="rebla-v5__featurebar-inner">
                      <div class="rebla-v5__feature"><svg viewBox="0 0 24 24"><path d="M12 2l8 4-8 4-8-4zM4 10l8 4 8-4M4 14l8 4 8-4"/></svg><div><strong>5-Stage Filtration</strong><small>Complete purification</small></div></div>
                      <div class="rebla-v5__feature"><svg viewBox="0 0 24 24"><path d="M12 3s6 6 6 11a6 6 0 1 1-12 0c0-5 6-11 6-11z"/></svg><div><strong>Removes 1,000+ Contaminants</strong><small>Powerful purification</small></div></div>
                      <div class="rebla-v5__feature"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8"/><path d="M12 4v3M20 12h-3M12 20v-3M4 12h3"/></svg><div><strong>High Performance RO Membrane</strong><small>Built for reliable flow</small></div></div>
                      <div class="rebla-v5__feature"><svg viewBox="0 0 24 24"><path d="M3 5h18v14H3zM3 9h18M7 5v14M11 5v14"/></svg><div><strong>All-in-One System</strong><small>Compact. Complete. Convenient.</small></div></div>
                    </div>
                  </div>
                </div>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </nav>

      <div class="rebla-v5__actions">
        <button type="button" class="rebla-v5__action"  aria-label="Search" data-rebla-search-trigger aria-expanded="false"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M16.5 16.5L21 21"/></svg></button>
        <a class="rebla-v5__action" href="{{ routes.account_url }}" aria-label="Account"><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c1-5 4-7 8-7s7 2 8 7"/></svg></a>
        <a class="rebla-v5__action" href="{{ routes.cart_url }}" aria-label="Cart"><svg viewBox="0 0 24 24"><path d="M3 4h2l2 12h11l2-8H6"/><circle cx="9" cy="20" r="1"/><circle cx="18" cy="20" r="1"/></svg>{% if cart.item_count > 0 %}<span class="rebla-v5__badge">{{ cart.item_count }}</span>{% endif %}</a>
      </div>
    </div>
  </header>

  <div class="rebla-v5__sticky">
    <div class="rebla-v5__sticky-inner">
      <a class="rebla-v5__brand" href="{{ routes.root_url }}">
        {% if section.settings.logo != blank %}{{ section.settings.logo | image_url: width: 360 | image_tag: class: 'rebla-v5__logo', loading: 'lazy', alt: shop.name }}{% else %}<span class="rebla-v5__name">{{ shop.name }}</span>{% endif %}
      </a>
      <nav aria-label="Sticky navigation"><ul class="rebla-v5__menu">{% for link in nav_menu.links %}<li><a class="rebla-v5__link" href="{{ link.url }}">{{ link.title }}</a></li>{% endfor %}</ul></nav>
      <div class="rebla-v5__actions">
        <button type="button" class="rebla-v5__action"  aria-label="Search" data-rebla-search-trigger aria-expanded="false"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M16.5 16.5L21 21"/></svg></button>
        <a class="rebla-v5__action" href="{{ routes.account_url }}" aria-label="Account"><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c1-5 4-7 8-7s7 2 8 7"/></svg></a>
        <a class="rebla-v5__action" href="{{ routes.cart_url }}" aria-label="Cart"><svg viewBox="0 0 24 24"><path d="M3 4h2l2 12h11l2-8H6"/><circle cx="9" cy="20" r="1"/><circle cx="18" cy="20" r="1"/></svg>{% if cart.item_count > 0 %}<span class="rebla-v5__badge">{{ cart.item_count }}</span>{% endif %}</a>
      </div>
    </div>
  </div>

  <header class="rebla-v5__mobile">
    <div class="rebla-v5__mobile-top">
      <div class="rebla-v5__mobile-benefit"><svg viewBox="0 0 24 24"><path d="M3 6h11v10H3zM14 9h4l3 3v4h-7z"/></svg><span>Free Shipping</span></div>
      <div class="rebla-v5__mobile-benefit"><svg viewBox="0 0 24 24"><path d="M12 3l7 3v5c0 5-3 8-7 10-4-2-7-5-7-10V6z"/></svg><span>2-Year Warranty</span></div>
      <a class="rebla-v5__mobile-benefit" href="tel:{{ section.settings.phone | remove: ' ' }}"><svg viewBox="0 0 24 24"><path d="M6 3l4 4-2 3c1.5 3 3 4.5 6 6l3-2 4 4-2 3c-8 0-16-8-16-16z"/></svg><span>{{ section.settings.phone }}</span></a>
    </div>
    <div class="rebla-v5__mobile-main">
      <button class="rebla-v5__hamburger" type="button" aria-label="Open menu"><svg viewBox="0 0 24 24"><path d="M4 7h16M4 12h16M4 17h16"/></svg></button>
      <a class="rebla-v5__mobile-brand" href="{{ routes.root_url }}">{% if section.settings.logo != blank %}{{ section.settings.logo | image_url: width: 360 | image_tag: class: 'rebla-v5__logo', loading: 'eager', alt: shop.name }}{% else %}<span class="rebla-v5__name">{{ shop.name }}</span>{% endif %}</a>
      <div class="rebla-v5__mobile-actions">
        <button type="button" class="rebla-v5__action"  aria-label="Search" data-rebla-search-trigger aria-expanded="false"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M16.5 16.5L21 21"/></svg></button>
        <a class="rebla-v5__action" href="{{ routes.account_url }}" aria-label="Account"><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c1-5 4-7 8-7s7 2 8 7"/></svg></a>
        <a class="rebla-v5__action" href="{{ routes.cart_url }}" aria-label="Cart"><svg viewBox="0 0 24 24"><path d="M3 4h2l2 12h11l2-8H6"/><circle cx="9" cy="20" r="1"/><circle cx="18" cy="20" r="1"/></svg>{% if cart.item_count > 0 %}<span class="rebla-v5__badge">{{ cart.item_count }}</span>{% endif %}</a>
      </div>
    </div>
  </header>

  <div class="rebla-v5__drawer" aria-hidden="true">
    <div class="rebla-v5__backdrop"></div>
    <aside class="rebla-v5__panel">
      <div class="rebla-v5__drawer-head"><strong>Menu</strong><button class="rebla-v5__close" type="button" aria-label="Close menu">×</button></div>
      <ul class="rebla-v5__drawer-list">
        {% for link in nav_menu.links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a>{% if link.links != blank %}<ul class="rebla-v5__drawer-sub">{% for child in link.links %}<li><a href="{{ child.url }}">{{ child.title }}</a></li>{% endfor %}</ul>{% endif %}</li>
        {% endfor %}
      </ul>
    </aside>
  </div>
</div>

<script>
(() => {
  const root = document.getElementById('ReblaV5-{{ section.id }}');
  if (!root || root.dataset.ready === 'true') return;
  root.dataset.ready = 'true';

  const syncScroll = () => root.classList.toggle('is-scrolled', window.scrollY > 150);
  syncScroll();
  window.addEventListener('scroll', syncScroll, { passive: true });

  const drawer = root.querySelector('.rebla-v5__drawer');
  const openBtn = root.querySelector('.rebla-v5__hamburger');
  const closeBtn = root.querySelector('.rebla-v5__close');
  const backdrop = root.querySelector('.rebla-v5__backdrop');

  const setDrawer = (open) => {
    drawer.classList.toggle('is-open', open);
    drawer.setAttribute('aria-hidden', String(!open));
    document.documentElement.style.overflow = open ? 'hidden' : '';
  };

  openBtn?.addEventListener('click', () => setDrawer(true));
  closeBtn?.addEventListener('click', () => setDrawer(false));
  backdrop?.addEventListener('click', () => setDrawer(false));
  document.addEventListener('keydown', e => { if (e.key === 'Escape') setDrawer(false); });
})();
</script>


<style>
  .rebla-search-overlay-v6[hidden]{display:none!important}
  .rebla-search-overlay-v6{position:fixed;inset:0;z-index:9999;background:rgba(10,24,51,.18);backdrop-filter:blur(4px);padding:92px 20px 20px}
  .rebla-search-overlay-v6__box{max-width:720px;margin:0 auto;background:#fff;border:1px solid rgba(10,24,51,.10);border-radius:18px;box-shadow:0 24px 70px rgba(10,24,51,.18);padding:14px}
  .rebla-search-overlay-v6 form{display:flex;align-items:center;gap:10px}
  .rebla-search-overlay-v6 input{width:100%;height:52px;border:0;outline:0;font:inherit;font-size:16px;color:#0a1833;background:transparent;padding:0 10px}
  .rebla-search-overlay-v6 button{border:0;background:transparent;cursor:pointer;color:#0a1833}
  .rebla-search-overlay-v6__submit{height:44px;padding:0 18px!important;border-radius:12px!important;background:#1e6bff!important;color:#fff!important;font-weight:700}
  .rebla-search-overlay-v6__close{font-size:26px;line-height:1;padding:8px!important}
  .rebla-v5__utility-nsf{display:flex;align-items:center;gap:9px}
  .rebla-v5__nsf-badge{display:inline-grid;place-items:center;width:28px;height:28px;border:1.5px solid currentColor;border-radius:50%;font-size:9px;font-weight:800}
  @media(max-width:749px){.rebla-search-overlay-v6{padding-top:76px}.rebla-v5__utility-nsf{display:none}}
</style>

<div id="reblaSearchOverlayV6" class="rebla-search-overlay-v6" hidden>
  <div class="rebla-search-overlay-v6__box" role="dialog" aria-modal="true" aria-label="Search">
    <form action="{{ routes.search_url }}" method="get" role="search">
      <input id="reblaSearchInputV6" type="search" name="q" placeholder="Search products, filters and parts…" autocomplete="off">
      <button class="rebla-search-overlay-v6__submit" type="submit">Search</button>
      <button class="rebla-search-overlay-v6__close" type="button" aria-label="Close search">×</button>
    </form>
  </div>
</div>

<script>
(function(){
  const overlay = document.getElementById('reblaSearchOverlayV6');
  if (!overlay) return;
  const input = document.getElementById('reblaSearchInputV6');
  const close = () => {
    overlay.hidden = true;
    document.querySelectorAll('[data-rebla-search-trigger]').forEach(el => el.setAttribute('aria-expanded','false'));
  };
  document.addEventListener('click', function(e){
    const trigger = e.target.closest('[data-rebla-search-trigger]');
    if (trigger) {
      e.preventDefault();
      e.stopPropagation();
      overlay.hidden = false;
      trigger.setAttribute('aria-expanded','true');
      setTimeout(() => input && input.focus(), 30);
      return;
    }
    if (e.target === overlay || e.target.closest('.rebla-search-overlay-v6__close')) close();
  });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
})();
</script>

