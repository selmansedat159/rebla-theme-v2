<script>
(() => {
  const root = document.getElementById('ReblaV5-{{ section.id }}');
  if (!root) return;

  if (root._reblaStickyHandler) {
    window.removeEventListener('scroll', root._reblaStickyHandler);
  }

  let stickyActive = root.classList.contains('is-scrolled');
  let stickyFrame = null;

  const updateSticky = () => {
    if (stickyFrame) return;

    stickyFrame = requestAnimationFrame(() => {
      const y = window.pageYOffset || document.documentElement.scrollTop || 0;

      if (!stickyActive && y >= 120) {
        stickyActive = true;
        root.classList.add('is-scrolled');
      } else if (stickyActive && y <= 40) {
        stickyActive = false;
        root.classList.remove('is-scrolled');
      }

      stickyFrame = null;
    });
  };

  root._reblaStickyHandler = updateSticky;
  window.addEventListener('scroll', updateSticky, { passive: true });
  updateSticky();



  const desktopSentinel = root.querySelector('.rebla-v5__desktop-sentinel');

if (desktopSentinel && 'IntersectionObserver' in window) {
  if (root._reblaDesktopObserver) root._reblaDesktopObserver.disconnect();

  root._reblaDesktopObserver = new IntersectionObserver(
    ([entry]) => {
      root.classList.toggle('is-desktop-scrolled', !entry.isIntersecting);
    },
    { root: null, threshold: 0 }
  );

  root._reblaDesktopObserver.observe(desktopSentinel);
}

window.addEventListener('scroll', updateDesktopSticky, { passive: true });
updateDesktopSticky();

  const drawer = root.querySelector('.rebla-v5__drawer');
  const openBtn = root.querySelector('.rebla-v5__hamburger');
  const closeBtn = root.querySelector('.rebla-v5__close');
  const backdrop = root.querySelector('.rebla-v5__backdrop');

  const setDrawer = (open) => {
    drawer.classList.toggle('is-open', open);
    drawer.setAttribute('aria-hidden', String(!open));
    document.documentElement.style.overflow = open ? 'hidden' : '';
  };

  openBtn?.addEventListener('click', () => setDrawer(true));
  closeBtn?.addEventListener('click', () => setDrawer(false));
  backdrop?.addEventListener('click', () => setDrawer(false));
  document.addEventListener('keydown', e => { if (e.key === 'Escape') setDrawer(false); });
})();
</script>


