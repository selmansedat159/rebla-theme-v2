<style>
@media(max-width:749px){
  /* Header her zaman görünür ve drawer'ın üstünde */
  .rebla-v5__mobile{
    position:relative;
    z-index:10001;
    background:#fff;
  }

  /* Drawer artık header'ın altından açılan çekmece */
  .rebla-v5__drawer{
    display:block!important;
    position:fixed!important;
    left:0;
    right:0;
    top:74px;
    bottom:0;
    z-index:9999;
    background:#fff!important;
    opacity:0;
    visibility:hidden;
    pointer-events:none;
    transform:translateX(-100%);
    transition:
      transform .38s cubic-bezier(.22,1,.36,1),
      opacity .2s ease,
      visibility 0s linear .38s;
  }

  .rebla-v5__drawer.is-open{
    opacity:1;
    visibility:visible;
    pointer-events:auto;
    transform:translateX(0);
    transition:
      transform .38s cubic-bezier(.22,1,.36,1),
      opacity .2s ease;
  }

  .rebla-v5__panel{
    height:calc(100dvh - 74px)!important;
    min-height:0;
  }

  /* Drawer içindeki eski üst bar ve X artık yok */
  .rebla-v5__drawer-head{
    display:none!important;
  }

  /* Menü üstten başlasın */
  .rebla-v5__drawer-nav{
    padding-top:22px!important;
  }

  /* Hamburger açıkken X'e dönüşsün */
  .rebla-v5__hamburger{
    position:relative;
  }
  .rebla-v5__hamburger svg{
    transition:opacity .18s ease;
  }
  .rebla-v5__hamburger.is-open svg{
    opacity:0;
  }
  .rebla-v5__hamburger.is-open:before,
  .rebla-v5__hamburger.is-open:after{
    content:"";
    position:absolute;
    left:50%;
    top:50%;
    width:22px;
    height:1.8px;
    border-radius:2px;
    background:currentColor;
  }
  .rebla-v5__hamburger.is-open:before{
    transform:translate(-50%,-50%) rotate(45deg);
  }
  .rebla-v5__hamburger.is-open:after{
    transform:translate(-50%,-50%) rotate(-45deg);
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function(){
  const root = document.getElementById('ReblaV5-{{ section.id }}');
  if (!root) return;

  const hamburger = root.querySelector('.rebla-v5__hamburger');
  const drawer = root.querySelector('.rebla-v5__drawer');
  if (!hamburger || !drawer) return;

  hamburger.addEventListener('click', function(){
    requestAnimationFrame(function(){
      hamburger.classList.toggle('is-open', drawer.classList.contains('is-open'));
    });
  });

  const observer = new MutationObserver(function(){
    hamburger.classList.toggle('is-open', drawer.classList.contains('is-open'));
  });
  observer.observe(drawer, { attributes:true, attributeFilter:['class'] });
});
</script>


<script>
(function(){
  const root = document.getElementById('ReblaV5-{{ section.id }}');
  if (!root) return;

  const hamburger = root.querySelector('.rebla-v5__hamburger');
  const drawer = root.querySelector('.rebla-v5__drawer');
  if (!hamburger || !drawer) return;

  /* Eski açma listener'larından önce çalışır; tek buton gerçek toggle olur */
  hamburger.addEventListener('click', function(e){
    e.preventDefault();
    e.stopImmediatePropagation();

    const opening = !drawer.classList.contains('is-open');

    drawer.classList.toggle('is-open', opening);
    drawer.setAttribute('aria-hidden', opening ? 'false' : 'true');
    hamburger.classList.toggle('is-open', opening);
    hamburger.setAttribute('aria-expanded', opening ? 'true' : 'false');

    document.documentElement.style.overflow = opening ? 'hidden' : '';
  }, true);
})();
</script>


<style>
@media (max-width: 749px) {
  /* Çekmece her zaman görünür headerın ALTINDAN başlar */
  #ReblaV5-{{ section.id }} .rebla-v5__drawer {
    top: var(--rebla-mobile-header-height, 78px) !important;
    height: calc(100dvh - var(--rebla-mobile-header-height, 78px)) !important;
    z-index: 9998 !important;
  }

  /* Normal ve sticky header çekmecenin üstünde kalır */
  #ReblaV5-{{ section.id }},
  #ReblaV5-{{ section.id }}.is-sticky,
  #ReblaV5-{{ section.id }} .rebla-v5__header,
  #ReblaV5-{{ section.id }} .rebla-v5__sticky {
    z-index: 10000 !important;
  }

  /* Menü içeriği artık headerın arkasına kaçmaz */
  #ReblaV5-{{ section.id }} .rebla-v5__panel {
    height: 100% !important;
    max-height: 100% !important;
    overflow-y: auto !important;
  }
}
</style>

<script>
(function () {
  const root = document.getElementById('ReblaV5-{{ section.id }}');
  if (!root) return;

  function syncMobileHeaderHeight() {
    if (window.innerWidth > 749) return;
    const visibleHeader =
      root.querySelector('.rebla-v5__sticky:not([hidden])') ||
      root.querySelector('.rebla-v5__header') ||
      root;
    const h = Math.round(visibleHeader.getBoundingClientRect().height) || 78;
    root.style.setProperty('--rebla-mobile-header-height', h + 'px');
  }

  syncMobileHeaderHeight();
  window.addEventListener('resize', syncMobileHeaderHeight);
  window.addEventListener('scroll', syncMobileHeaderHeight, { passive: true });
})();
</script>

