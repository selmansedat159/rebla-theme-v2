{% liquid
  assign logo_width = section.settings.logo_width | default: 180
  assign phone_href = section.settings.phone_number | remove: ' ' | remove: '(' | remove: ')' | remove: '-'
%}

<section id="ReblaHeader-{{ section.id }}" class="rh-shell">
  <div class="rh-header">
    <a class="rh-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 500 | image_tag: loading: 'eager', widths: '140,180,220,280,360', alt: shop.name }}
      {% else %}
        <span>{{ shop.name }}</span>
      {% endif %}
    </a>

    <nav class="rh-nav" aria-label="Main navigation">
      {% for link in section.settings.menu.links %}
        <div class="rh-nav-item{% if link.links != blank %} has-dropdown{% endif %}">
          <a href="{{ link.url }}" class="rh-nav-link">
            {{ link.title }}
            {% if link.links != blank %}
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m7 9.5 5 5 5-5"/></svg>
            {% endif %}
          </a>

          {% if link.links != blank %}
            <div class="rh-mega">
              <div class="rh-mega-inner">
                <a class="rh-feature-card" href="{{ section.settings.feature_link | default: link.url }}">
                  <div class="rh-feature-media">
                    {% if section.settings.feature_image != blank %}
                      {{ section.settings.feature_image | image_url: width: 700 | image_tag: loading: 'lazy', widths: '300,500,700', alt: section.settings.feature_heading }}
                    {% endif %}
                    <div class="rh-feature-copy">
                      <strong>{{ section.settings.feature_heading }}</strong>
                      <span>{{ section.settings.feature_cta }} →</span>
                    </div>
                  </div>
                </a>

                <div class="rh-mega-columns">
                  {% for child in link.links %}
                    <div class="rh-mega-col">
                      <a class="rh-mega-title" href="{{ child.url }}">{{ child.title }}</a>
                      {% for grandchild in child.links %}
                        <a href="{{ grandchild.url }}">{{ grandchild.title }}</a>
                      {% endfor %}
                      <a class="rh-view-all" href="{{ child.url }}">View All →</a>
                    </div>
                  {% endfor %}
                </div>
              </div>

              <div class="rh-benefits">
                <div><span class="rh-benefit-icon">▱</span><span><b>5-Stage Filtration</b><small>Complete purification</small></span></div>
                <div><span class="rh-benefit-icon">◯</span><span><b>Removes 1,000+ Contaminants</b><small>Powerful purification</small></span></div>
                <div><span class="rh-benefit-icon">✥</span><span><b>High Performance RO Membrane</b><small>Built for reliable flow</small></span></div>
                <div><span class="rh-benefit-icon">▦</span><span><b>All-in-One System</b><small>Compact. Complete. Convenient.</small></span></div>
              </div>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </nav>

    <div class="rh-actions">
      {% if section.settings.call_button_text != blank %}
        <a class="rh-call" href="tel:{{ phone_href }}">{{ section.settings.call_button_text }}</a>
      {% endif %}

      <button class="rh-icon rh-search-toggle" type="button" aria-label="Search">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m20 20-4-4"/></svg>
      </button>

      <a class="rh-icon" href="{{ routes.account_url }}" aria-label="Account">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="7" r="4"/><path d="M4.5 21c.7-5 3.2-7.5 7.5-7.5s6.8 2.5 7.5 7.5"/></svg>
      </a>

      <a class="rh-icon rh-cart" href="{{ routes.cart_url }}" aria-label="Cart">
        <svg viewBox="0 0 24 24"><path d="M3 4h2l2 11h10l2-8H6"/><circle cx="9" cy="20" r="1"/><circle cx="17" cy="20" r="1"/></svg>
        {% if cart.item_count > 0 %}<span>{{ cart.item_count }}</span>{% endif %}
      </a>

      <span class="rh-flag" aria-label="United States">🇺🇸</span>
    </div>

    <button class="rh-menu-toggle" type="button" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="rh-search-panel" hidden>
    <form action="{{ routes.search_url }}" method="get" role="search">
      <input type="search" name="q" placeholder="Search products..." autocomplete="off">
      <button type="submit" aria-label="Submit search">→</button>
    </form>
  </div>

  <div class="rh-mobile-drawer" hidden>
    {% for link in section.settings.menu.links %}
      <a href="{{ link.url }}">{{ link.title }}</a>
      {% for child in link.links %}
        <a class="rh-mobile-child" href="{{ child.url }}">{{ child.title }}</a>
      {% endfor %}
    {% endfor %}
    {% if section.settings.call_button_text != blank %}
      <a class="rh-mobile-call" href="tel:{{ phone_href }}">{{ section.settings.call_button_text }}</a>
    {% endif %}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }}{
    position:sticky;
    top:0;
    z-index:1000;
    height:0;
    overflow:visible;
  }

  #ReblaHeader-{{ section.id }}{
    --rh-blue:{{ section.settings.cta_background }};
    --rh-text:#081a33;
    --rh-radius:16px;
    width:min(calc(100% - 7.5vw), 1410px);
    margin:28px auto 0;
    font-family:inherit;
    color:var(--rh-text);
    position:relative;
  }

  #ReblaHeader-{{ section.id }} *{box-sizing:border-box}

  #ReblaHeader-{{ section.id }} .rh-header{
    height:106px;
    display:grid;
    grid-template-columns:190px minmax(420px,1fr) auto;
    align-items:center;
    gap:28px;
    padding:0 34px 0 48px;
    background:#fff;
    border-radius:var(--rh-radius);
    box-shadow:0 14px 38px rgba(8,26,51,.10);
    transition:height .22s ease,border-radius .22s ease,box-shadow .22s ease;
  }

  #ReblaHeader-{{ section.id }} .rh-logo{display:flex;align-items:center;width:{{ logo_width }}px;max-width:100%}
  #ReblaHeader-{{ section.id }} .rh-logo img{display:block;width:100%;height:auto}

  #ReblaHeader-{{ section.id }} .rh-nav{display:flex;align-items:center;justify-content:flex-start;gap:34px;height:100%}
  #ReblaHeader-{{ section.id }} .rh-nav-item{height:100%;display:flex;align-items:center}
  #ReblaHeader-{{ section.id }} .rh-nav-link{height:100%;display:flex;align-items:center;gap:7px;color:var(--rh-text);text-decoration:none;font-size:15px;font-weight:700;white-space:nowrap;position:relative}
  #ReblaHeader-{{ section.id }} .rh-nav-link svg{width:15px;height:15px;fill:none;stroke:currentColor;stroke-width:2}
  #ReblaHeader-{{ section.id }} .rh-nav-link:after{content:"";position:absolute;left:0;right:0;bottom:0;height:2px;background:var(--rh-blue);transform:scaleX(0);transition:.2s}
  #ReblaHeader-{{ section.id }} .rh-nav-item:hover>.rh-nav-link:after{transform:scaleX(1)}

  #ReblaHeader-{{ section.id }} .rh-actions{display:flex;align-items:center;gap:20px}
  #ReblaHeader-{{ section.id }} .rh-call{display:flex;align-items:center;justify-content:center;min-height:46px;padding:0 21px;border-radius:8px;background:var(--rh-blue);color:{{ section.settings.cta_text_color }};text-decoration:none;font-size:13px;font-weight:800;white-space:nowrap;box-shadow:0 9px 20px color-mix(in srgb,var(--rh-blue) 25%,transparent)}
  #ReblaHeader-{{ section.id }} .rh-icon{width:25px;height:25px;display:grid;place-items:center;padding:0;border:0;background:none;color:var(--rh-text);text-decoration:none;position:relative;cursor:pointer}
  #ReblaHeader-{{ section.id }} .rh-icon svg{width:24px;height:24px;fill:none;stroke:currentColor;stroke-width:1.9;stroke-linecap:round;stroke-linejoin:round}
  #ReblaHeader-{{ section.id }} .rh-cart span{position:absolute;right:-8px;top:-9px;min-width:19px;height:19px;padding:0 5px;border-radius:20px;background:#2169f3;color:#fff;font-size:11px;font-weight:800;display:grid;place-items:center}
  #ReblaHeader-{{ section.id }} .rh-flag{width:29px;height:29px;border-radius:50%;display:grid;place-items:center;overflow:hidden;font-size:25px;line-height:1;box-shadow:0 3px 10px rgba(0,0,0,.12)}
  #ReblaHeader-{{ section.id }} .rh-menu-toggle{display:none}

  #ReblaHeader-{{ section.id }} .rh-mega{
    display:none;
    position:absolute;
    left:0;
    right:0;
    top:calc(100% + 1px);
    background:#fff;
    border-radius:0 0 16px 16px;
    box-shadow:0 24px 45px rgba(8,26,51,.12);
    overflow:hidden;
  }
  #ReblaHeader-{{ section.id }} .has-dropdown:hover .rh-mega{display:block}
  #ReblaHeader-{{ section.id }} .rh-mega-inner{display:grid;grid-template-columns:250px 1fr;gap:50px;padding:18px 24px 18px}
  #ReblaHeader-{{ section.id }} .rh-feature-card{text-decoration:none;color:var(--rh-text)}
  #ReblaHeader-{{ section.id }} .rh-feature-media{height:280px;border-radius:15px;overflow:hidden;position:relative;background:#f4f6f8}
  #ReblaHeader-{{ section.id }} .rh-feature-media img{width:100%;height:100%;object-fit:cover}
  #ReblaHeader-{{ section.id }} .rh-feature-copy{position:absolute;inset:0;padding:24px;display:flex;flex-direction:column;justify-content:space-between}
  #ReblaHeader-{{ section.id }} .rh-feature-copy strong{max-width:190px;font-size:25px;line-height:1.08}
  #ReblaHeader-{{ section.id }} .rh-feature-copy span{font-size:14px;font-weight:800}
  #ReblaHeader-{{ section.id }} .rh-mega-columns{display:grid;grid-template-columns:repeat(3,1fr)}
  #ReblaHeader-{{ section.id }} .rh-mega-col{padding:14px 25px;border-left:1px solid #e3e8ee;display:flex;flex-direction:column;gap:17px}
  #ReblaHeader-{{ section.id }} .rh-mega-col:first-child{border-left:0}
  #ReblaHeader-{{ section.id }} .rh-mega-col a{text-decoration:none;color:var(--rh-text);font-size:14px}
  #ReblaHeader-{{ section.id }} .rh-mega-title{font-size:13px!important;font-weight:800;text-transform:uppercase}
  #ReblaHeader-{{ section.id }} .rh-view-all{margin-top:6px;font-weight:800!important}
  #ReblaHeader-{{ section.id }} .rh-benefits{border-top:1px solid #e3e8ee;display:grid;grid-template-columns:repeat(4,1fr)}
  #ReblaHeader-{{ section.id }} .rh-benefits>div{min-height:80px;padding:0 28px;display:flex;align-items:center;gap:18px;border-left:1px solid #e3e8ee}
  #ReblaHeader-{{ section.id }} .rh-benefits>div:first-child{border-left:0}
  #ReblaHeader-{{ section.id }} .rh-benefit-icon{font-size:25px}
  #ReblaHeader-{{ section.id }} .rh-benefits b,#ReblaHeader-{{ section.id }} .rh-benefits small{display:block}
  #ReblaHeader-{{ section.id }} .rh-benefits b{font-size:13px}
  #ReblaHeader-{{ section.id }} .rh-benefits small{margin-top:5px;color:#6c7888;font-size:11px}

  #ReblaHeader-{{ section.id }} .rh-search-panel{margin-top:8px;background:#fff;border-radius:12px;box-shadow:0 16px 35px rgba(8,26,51,.12);padding:14px}
  #ReblaHeader-{{ section.id }} .rh-search-panel form{display:flex}
  #ReblaHeader-{{ section.id }} .rh-search-panel input{width:100%;border:0;outline:0;font:inherit;font-size:16px;padding:10px}
  #ReblaHeader-{{ section.id }} .rh-search-panel button{width:50px;border:0;background:var(--rh-blue);color:#fff;border-radius:8px;font-size:20px}
  #ReblaHeader-{{ section.id }} .rh-mobile-drawer{display:none}

  @media (max-width:1180px){
    #ReblaHeader-{{ section.id }} .rh-header{grid-template-columns:155px 1fr auto;padding-left:28px;gap:20px}
    #ReblaHeader-{{ section.id }} .rh-nav{gap:20px}
    #ReblaHeader-{{ section.id }} .rh-nav-link{font-size:13px}
    #ReblaHeader-{{ section.id }} .rh-actions{gap:14px}
    #ReblaHeader-{{ section.id }} .rh-call{padding:0 15px;font-size:12px}
  }

  @media (max-width:989px){
    #shopify-section-{{ section.id }}{height:auto}
    #ReblaHeader-{{ section.id }}{width:calc(100% - 24px);margin:12px auto 0}
    #ReblaHeader-{{ section.id }} .rh-header{height:72px;grid-template-columns:1fr auto auto;padding:0 18px;border-radius:13px}
    #ReblaHeader-{{ section.id }} .rh-logo{width:min({{ logo_width }}px,135px)}
    #ReblaHeader-{{ section.id }} .rh-nav,#ReblaHeader-{{ section.id }} .rh-call,#ReblaHeader-{{ section.id }} .rh-actions .rh-icon:not(.rh-cart){display:none}
    #ReblaHeader-{{ section.id }} .rh-actions{gap:12px}
    #ReblaHeader-{{ section.id }} .rh-flag{width:26px;height:26px;font-size:22px}
    #ReblaHeader-{{ section.id }} .rh-menu-toggle{width:28px;height:24px;border:0;background:none;padding:0;display:flex;flex-direction:column;justify-content:space-between}
    #ReblaHeader-{{ section.id }} .rh-menu-toggle span{height:2px;width:100%;background:var(--rh-text);border-radius:2px}
    #ReblaHeader-{{ section.id }} .rh-mobile-drawer{margin-top:8px;background:#fff;border-radius:13px;box-shadow:0 18px 40px rgba(8,26,51,.14);padding:18px}
    #ReblaHeader-{{ section.id }} .rh-mobile-drawer.is-open{display:flex;flex-direction:column;gap:16px}
    #ReblaHeader-{{ section.id }} .rh-mobile-drawer a{text-decoration:none;color:var(--rh-text);font-weight:700}
    #ReblaHeader-{{ section.id }} .rh-mobile-child{padding-left:16px;font-size:14px;font-weight:500!important}
    #ReblaHeader-{{ section.id }} .rh-mobile-call{margin-top:8px;padding:14px;text-align:center;border-radius:8px;background:var(--rh-blue);color:#fff!important}
  }
</style>

<script>
(() => {
  const root = document.getElementById('ReblaHeader-{{ section.id }}');
  if (!root) return;

  const searchToggle = root.querySelector('.rh-search-toggle');
  const searchPanel = root.querySelector('.rh-search-panel');
  const menuToggle = root.querySelector('.rh-menu-toggle');
  const drawer = root.querySelector('.rh-mobile-drawer');

  searchToggle?.addEventListener('click', () => {
    searchPanel.hidden = !searchPanel.hidden;
    if (!searchPanel.hidden) searchPanel.querySelector('input')?.focus();
  });

  menuToggle?.addEventListener('click', () => {
    drawer.hidden = false;
    drawer.classList.toggle('is-open');
  });
})();
</script>

{% schema %}
{
  "name": "Rebla Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 120,
      "max": 240,
      "step": 5,
      "default": 180,
      "unit": "px"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main menu"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone number",
      "default": "+1 (888) 557-3252"
    },
    {
      "type": "text",
      "id": "call_button_text",
      "label": "Call button text",
      "default": "TOLL FREE (888) 55 REBLA"
    },
    {
      "type": "color",
      "id": "cta_background",
      "label": "CTA background",
      "default": "#1E6BFF"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "CTA text color",
      "default": "#FFFFFF"
    },
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Mega menu feature image"
    },
    {
      "type": "text",
      "id": "feature_heading",
      "label": "Mega menu feature heading",
      "default": "Premium water, from the first drop to the last."
    },
    {
      "type": "text",
      "id": "feature_cta",
      "label": "Mega menu feature CTA",
      "default": "Shop System"
    },
    {
      "type": "url",
      "id": "feature_link",
      "label": "Mega menu feature link"
    }
  ],
  "presets": [
    {
      "name": "Rebla Header"
    }
  ]
}
{% endschema %}
